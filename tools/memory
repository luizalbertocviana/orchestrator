# Generate unique ID: mem_<timestamp>_<8_hex_chars>
generate_id() {
    local timestamp random
    timestamp=$(date +%s)
    random=$(od -An -tx1 -N4 /dev/urandom | tr -d ' \n')
    echo "mem_${timestamp}_${random}"
}

# Get current ISO 8601 timestamp
get_timestamp() {
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

# Validate that a value is in a list
validate_in() {
    local value="$1"
    local list="$2"
    local item
    for item in $list; do
        [[ "$value" == "$item" ]] && return 0
    done
    return 1
}

# Sanitize string for safe shell handling - escape special chars
# Uses jq to ensure valid JSON string encoding
sanitize_string() {
    local input="$1"
    echo -n "$input" | jq -Rs '.'
}

# Validate input for potentially dangerous shell patterns
# Returns 0 if safe, 1 if potentially dangerous
validate_input() {
    local input="$1"
    local danger_pattern='[|`$(){}\\;'"'"'<>!&*?]'
    
    if [[ "$input" =~ $danger_pattern ]]; then
        return 1
    fi
    return 0
}

# Validate storage path - directory writable, file creatable
validate_storage_path() {
    local dir
    dir=$(dirname "$MEMORY_FILE")
    
    if [[ ! -d "$dir" ]]; then
        if ! mkdir -p "$dir" 2>/dev/null; then
            error "create: cannot create directory: $dir"
            exit $EXIT_STORAGE_ERROR
        fi
    fi
    
    if [[ ! -w "$dir" ]]; then
        error "create: directory not writable: $dir"
        exit $EXIT_STORAGE_ERROR
    fi
    
    if [[ -f "$MEMORY_FILE" && ! -w "$MEMORY_FILE" ]]; then
        error "create: file not writable: $MEMORY_FILE"
        exit $EXIT_STORAGE_ERROR
    fi
}

# Check storage thresholds and warn if exceeded
check_storage_thresholds() {
    if [[ ! -f "$MEMORY_FILE" ]]; then
        return
    fi
    
    local item_count file_size_mb
    item_count=$(wc -l < "$MEMORY_FILE")
    file_size_mb=$(du -m "$MEMORY_FILE" | cut -f1)
    
    if [[ "$item_count" -ge $THRESHOLD_ITEMS ]]; then
        warn "storage approaching threshold: $item_count items (recommended: < $THRESHOLD_ITEMS). Consider archiving old items."
    fi
    
    if [[ "$file_size_mb" -ge $THRESHOLD_SIZE_MB ]]; then
        warn "storage approaching threshold: ${file_size_mb}MB (recommended: < ${THRESHOLD_SIZE_MB}MB). Consider exporting and archiving."
    fi
}

# =============================================================================
# File Locking Functions
# =============================================================================

# Acquire exclusive lock for write operations
acquire_exclusive_lock() {
    local lockfile="${MEMORY_FILE}.lock"
    exec 200>"$lockfile"
    local start_time
    start_time=$(date +%s)
    if ! flock -x -w "$LOCK_TIMEOUT" 200; then
        error "create: failed to acquire lock (timeout after ${LOCK_TIMEOUT}s)"
        exit $EXIT_STORAGE_ERROR
    fi
    local elapsed
    elapsed=$(($(date +%s) - start_time))
    if [[ "$elapsed" -gt 1 ]]; then
        warn "lock wait time: ${elapsed}s for write operation"
    fi
}

# Acquire shared lock for read operations
acquire_shared_lock() {
    local lockfile="${MEMORY_FILE}.lock"
    exec 200>"$lockfile"
    local start_time
    start_time=$(date +%s)
    if ! flock -s -w "$LOCK_TIMEOUT" 200; then
        error "list: failed to acquire lock (timeout after ${LOCK_TIMEOUT}s)"
        exit $EXIT_STORAGE_ERROR
    fi
    local elapsed
    elapsed=$(($(date +%s) - start_time))
    if [[ "$elapsed" -gt 1 ]]; then
        warn "lock wait time: ${elapsed}s for read operation"
    fi
}

# =============================================================================
# JSONL Storage Primitives
# =============================================================================

# Ensure storage file exists
ensure_storage() {
    if [[ ! -f "$MEMORY_FILE" ]]; then
        validate_storage_path
        touch "$MEMORY_FILE" || {
            error "create: cannot write to storage file: $MEMORY_FILE"
            exit $EXIT_STORAGE_ERROR
        }
        chmod 600 "$MEMORY_FILE"
    fi
}

# Read all items from storage (outputs JSONL)
read_all_items() {
    if [[ -f "$MEMORY_FILE" ]]; then
        cat "$MEMORY_FILE"
    fi
}

# Append item to storage (as pretty-printed JSON in array)
append_item() {
    local new_item="$1"
    local temp_file
    temp_file=$(mktemp) || {
        error "create: failed to create temp file"
        exit $EXIT_STORAGE_ERROR
    }

    # Check if file exists and is writable (or directory is writable for new files)
    if [[ -f "$MEMORY_FILE" && ! -w "$MEMORY_FILE" ]]; then
        rm -f "$temp_file"
        error "create: file not writable: $MEMORY_FILE"
        exit $EXIT_STORAGE_ERROR
    fi
    
    # Add to array, write pretty-printed
    if [[ -s "$MEMORY_FILE" ]] && jq empty "$MEMORY_FILE" 2>/dev/null; then
        jq --argjson item "$new_item" '. + [$item]' "$MEMORY_FILE" > "$temp_file" || {
            rm -f "$temp_file"
            error "create: failed to write to storage"
            exit $EXIT_STORAGE_ERROR
        }
    else
        # Initialize as array
        echo "$new_item" | jq -s '.' > "$temp_file" || {
            rm -f "$temp_file"
            error "create: failed to write to storage"
            exit $EXIT_STORAGE_ERROR
        }
    fi
    mv -f "$temp_file" "$MEMORY_FILE" || {
        error "create: failed to replace storage file"
        exit $EXIT_STORAGE_ERROR
    }
}

# Update item in storage by ID
update_item_in_storage() {
    local id="$1"
    local new_json="$2"
    local temp_file
    temp_file=$(mktemp) || {
        error "update: failed to create temp file"
        exit $EXIT_STORAGE_ERROR
    }

    # Update item in array, write pretty-printed
    jq --arg id "$id" --argjson new "$new_json" '
        [.[] | if .id == $id then $new else . end]
    ' "$MEMORY_FILE" > "$temp_file" || {
        rm -f "$temp_file"
        error "update: failed to update item"
        exit $EXIT_STORAGE_ERROR
    }

    mv "$temp_file" "$MEMORY_FILE" || {
        error "update: failed to replace storage file"
        exit $EXIT_STORAGE_ERROR
    }
}

# Delete item from storage by ID
delete_item_from_storage() {
    local id="$1"
    local temp_file
    temp_file=$(mktemp) || {
        error "delete: failed to create temp file"
        exit $EXIT_STORAGE_ERROR
    }

    # Filter out item from array, write pretty-printed
    jq --arg id "$id" '
        [.[] | select(.id != $id)]
    ' "$MEMORY_FILE" > "$temp_file" || {
        rm -f "$temp_file"
        error "delete: failed to delete item"
        exit $EXIT_STORAGE_ERROR
    }

    mv "$temp_file" "$MEMORY_FILE" || {
        error "delete: failed to replace storage file"
        exit $EXIT_STORAGE_ERROR
    }
}

# Check if item exists
item_exists() {
    local id="$1"
    local count
    count=$(jq --arg id "$id" '[.[] | select(.id == $id)] | length' "$MEMORY_FILE" 2>/dev/null)
    [[ "$count" -gt 0 ]]
}

