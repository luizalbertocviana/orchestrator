# =============================================================================
# Command: create
# =============================================================================

cmd_create() {
    local type=""
    local title=""
    local content=""
    local priority=2
    local assignee=""
    local status="pending"
    local tags=""

    # Type-specific fields
    local metric_name="" metric_value="" metric_unit="" metric_trend=""
    local decision_context="" decision_consequence="" decision_alternatives="" decision_status=""
    local artifact_path="" artifact_checksum="" artifact_type=""
    local blocker_urgency="" blocker_blocked_by="" blocker_affects="" blocker_resolution=""
    local task_due_iteration=""
    local note_category=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)
                type="$2"
                shift 2
                ;;
            --content)
                content="$2"
                shift 2
                ;;
            --priority)
                priority="$2"
                shift 2
                ;;
            --assignee)
                assignee="$2"
                shift 2
                ;;
            --status)
                status="$2"
                shift 2
                ;;
            --tags)
                tags="$2"
                shift 2
                ;;
            --name)
                metric_name="$2"
                shift 2
                ;;
            --value)
                metric_value="$2"
                shift 2
                ;;
            --unit)
                metric_unit="$2"
                shift 2
                ;;
            --trend)
                metric_trend="$2"
                shift 2
                ;;
            --context)
                decision_context="$2"
                shift 2
                ;;
            --consequence)
                decision_consequence="$2"
                shift 2
                ;;
            --alternatives)
                decision_alternatives="$2"
                shift 2
                ;;
            --decision-status)
                decision_status="$2"
                shift 2
                ;;
            --path)
                artifact_path="$2"
                shift 2
                ;;
            --checksum)
                artifact_checksum="$2"
                shift 2
                ;;
            --artifact-type)
                artifact_type="$2"
                shift 2
                ;;
            --urgency)
                blocker_urgency="$2"
                shift 2
                ;;
            --blocked-by)
                blocker_blocked_by="$2"
                shift 2
                ;;
            --affects)
                blocker_affects="$2"
                shift 2
                ;;
            --resolution)
                blocker_resolution="$2"
                shift 2
                ;;
            --due-iteration)
                task_due_iteration="$2"
                shift 2
                ;;
            --category)
                note_category="$2"
                shift 2
                ;;
            -*)
                error "create: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                if [[ -z "$title" ]]; then
                    title="$1"
                fi
                shift
                ;;
        esac
    done

    # Validate required fields
    if [[ -z "$type" ]]; then
        error "create: --type is required"
        exit $EXIT_INVALID_ARGS
    fi

    if ! validate_in "$type" "$VALID_TYPES"; then
        error "create: invalid type '$type'. Valid types: $VALID_TYPES"
        exit $EXIT_INVALID_ARGS
    fi

    # Validate input for shell injection patterns (warn but don't block)
    if [[ -n "$title" ]] && ! validate_input "$title"; then
        error "create: warning: title contains special shell characters - will be escaped"
    fi
    if [[ -n "$content" ]] && ! validate_input "$content"; then
        error "create: warning: content contains special shell characters - will be escaped"
    fi

    # Title required for all except metric
    if [[ "$type" != "metric" && -z "$title" ]]; then
        error "create: title is required for type '$type'"
        exit $EXIT_INVALID_ARGS
    fi

    # Validate priority
    if ! validate_in "$priority" "$VALID_PRIORITIES"; then
        error "create: invalid priority '$priority'. Valid: 0-4"
        exit $EXIT_INVALID_ARGS
    fi

    # Validate status
    if ! validate_in "$status" "$VALID_STATUSES"; then
        error "create: invalid status '$status'. Valid: $VALID_STATUSES"
        exit $EXIT_INVALID_ARGS
    fi

    # Type-specific validation
    case "$type" in
        metric)
            if [[ -z "$metric_name" || -z "$metric_value" ]]; then
                error "create: --name and --value are required for metric type"
                exit $EXIT_INVALID_ARGS
            fi
            if [[ -n "$metric_unit" ]] && ! validate_in "$metric_unit" "$VALID_UNITS"; then
                error "create: invalid unit '$metric_unit'. Valid: $VALID_UNITS"
                exit $EXIT_INVALID_ARGS
            fi
            ;;
        decision)
            if [[ -n "$decision_status" ]] && ! validate_in "$decision_status" "$VALID_DECISION_STATUS"; then
                error "create: invalid decision status '$decision_status'. Valid: $VALID_DECISION_STATUS"
                exit $EXIT_INVALID_ARGS
            fi
            ;;
        artifact)
            if [[ -n "$artifact_type" ]] && ! validate_in "$artifact_type" "$VALID_ARTIFACT_TYPES"; then
                error "create: invalid artifact type '$artifact_type'. Valid: $VALID_ARTIFACT_TYPES"
                exit $EXIT_INVALID_ARGS
            fi
            ;;
        blocker)
            if [[ -n "$blocker_urgency" ]] && ! validate_in "$blocker_urgency" "$VALID_URGENCY"; then
                error "create: invalid urgency '$blocker_urgency'. Valid: $VALID_URGENCY"
                exit $EXIT_INVALID_ARGS
            fi
            ;;
    esac

    # Generate ID and timestamp
    local id timestamp_created
    id=$(generate_id)
    timestamp_created=$(get_timestamp)

    # Build tags array
    local tags_json="[]"
    if [[ -n "$tags" ]]; then
        tags_json=$(echo "$tags" | tr ',' '\n' | jq -R . | jq -s .)
    fi

    # Build type-specific metadata
    local type_specific_json="{}"
    case "$type" in
        task)
            type_specific_json=$(jq -n \
                --arg due_iteration "${task_due_iteration:-$MEMORY_ITERATION}" \
                '{due_iteration: ($due_iteration | tonumber)}')
            ;;
        note)
            type_specific_json=$(jq -n \
                --arg category "${note_category:-}" \
                '{category: $category}')
            ;;
        metric)
            type_specific_json=$(jq -n \
                --arg name "$metric_name" \
                --argjson value "$metric_value" \
                --arg unit "${metric_unit:-count}" \
                --arg trend "${metric_trend:-}" \
                '{name: $name, value: $value, unit: $unit, trend: $trend}')
            ;;
        decision)
            local alternatives_json="[]"
            if [[ -n "$decision_alternatives" ]]; then
                alternatives_json=$(echo "$decision_alternatives" | tr ',' '\n' | jq -R . | jq -s .)
            fi
            type_specific_json=$(jq -n \
                --arg context "${decision_context:-}" \
                --arg consequence "${decision_consequence:-}" \
                --argjson alternatives "$alternatives_json" \
                --arg status "${decision_status:-proposed}" \
                '{context: $context, consequence: $consequence, alternatives: $alternatives, status: $status}')
            ;;
        artifact)
            type_specific_json=$(jq -n \
                --arg path "${artifact_path:-}" \
                --arg checksum "${artifact_checksum:-}" \
                --arg artifact_type "${artifact_type:-code}" \
                '{path: $path, checksum: $checksum, artifact_type: $artifact_type}')
            ;;
        blocker)
            local affects_json="[]"
            if [[ -n "$blocker_affects" ]]; then
                affects_json=$(echo "$blocker_affects" | tr ',' '\n' | jq -R . | jq -s .)
            fi
            type_specific_json=$(jq -n \
                --arg urgency "${blocker_urgency:-medium}" \
                --arg blocked_by "${blocker_blocked_by:-}" \
                --argjson affects "$affects_json" \
                --arg resolution "${blocker_resolution:-}" \
                '{urgency: $urgency, blocked_by: $blocked_by, affects: $affects, resolution: $resolution}')
            ;;
    esac

    # Build complete JSON object
    local json
    json=$(jq -n \
        --arg id "$id" \
        --arg type "$type" \
        --arg title "$title" \
        --arg content "$content" \
        --argjson priority "$priority" \
        --arg assignee "$assignee" \
        --arg status "$status" \
        --argjson tags "$tags_json" \
        --argjson created_iteration "$MEMORY_ITERATION" \
        --arg created_by "$MEMORY_AGENT" \
        --argjson type_specific "$type_specific_json" \
        --arg timestamp_created "$timestamp_created" \
        '{
            id: $id,
            type: $type,
            title: $title,
            content: $content,
            metadata: {
                priority: $priority,
                assignee: $assignee,
                status: $status,
                tags: $tags,
                created_iteration: $created_iteration,
                created_by: $created_by,
                type_specific: $type_specific
            },
            relations: [],
            timestamp_created: $timestamp_created,
            timestamp_updated: $timestamp_created
        }')

    # Acquire lock and write
    acquire_exclusive_lock
    ensure_storage
    append_item "$json"

    # Output created item
    echo "$json"
    exit $EXIT_SUCCESS
}

# =============================================================================
# Command: list
# =============================================================================

cmd_list() {
    local type=""
    local status=""
    local assignee=""
    local priority=""
    local priority_min=""
    local priority_max=""
    local tags=()
    local since=""
    local until_iter=""
    local name=""
    local limit=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)
                type="$2"
                shift 2
                ;;
            --status)
                status="$2"
                shift 2
                ;;
            --assignee)
                assignee="$2"
                shift 2
                ;;
            --priority)
                priority="$2"
                shift 2
                ;;
            --priority-min)
                priority_min="$2"
                shift 2
                ;;
            --priority-max)
                priority_max="$2"
                shift 2
                ;;
            --tag)
                tags+=("$2")
                shift 2
                ;;
            --since)
                since="$2"
                shift 2
                ;;
            --until)
                until_iter="$2"
                shift 2
                ;;
            --name)
                name="$2"
                shift 2
                ;;
            --limit)
                limit="$2"
                shift 2
                ;;
            -*)
                error "list: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                shift
                ;;
        esac
    done

    # Acquire shared lock and read
    acquire_shared_lock

    if [[ ! -f "$MEMORY_FILE" ]]; then
        exit $EXIT_SUCCESS
    fi

    check_storage_thresholds

    # Build jq filter
    local filter='.'
    local conditions=()

    if [[ -n "$type" ]]; then
        conditions+=("select(.type == \"$type\")")
    fi

    if [[ -n "$status" ]]; then
        conditions+=("select(.metadata.status == \"$status\")")
    fi

    if [[ -n "$assignee" ]]; then
        conditions+=("select(.metadata.assignee == \"$assignee\")")
    fi

    if [[ -n "$priority" ]]; then
        conditions+=("select(.metadata.priority == $priority)")
    fi

    if [[ -n "$priority_min" ]]; then
        conditions+=("select(.metadata.priority >= $priority_min)")
    fi

    if [[ -n "$priority_max" ]]; then
        conditions+=("select(.metadata.priority <= $priority_max)")
    fi

    if [[ ${#tags[@]} -gt 0 ]]; then
        for tag in "${tags[@]}"; do
            conditions+=("select(.metadata.tags | index(\"$tag\"))")
        done
    fi

    if [[ -n "$since" ]]; then
        conditions+=("select(.metadata.created_iteration >= $since)")
    fi

    if [[ -n "$until_iter" ]]; then
        conditions+=("select(.metadata.created_iteration <= $until_iter)")
    fi

    if [[ -n "$name" ]]; then
        conditions+=("select(.metadata.type_specific.name == \"$name\")")
    fi

    # Apply conditions - chain select filters for JSONL output
    if [[ ${#conditions[@]} -gt 0 ]]; then
        for cond in "${conditions[@]}"; do
            filter="$filter | $cond"
        done
    fi

    # Read and filter from JSON array storage
    local result
    result=$(jq -c '.[]' "$MEMORY_FILE" 2>/dev/null | jq -c "$filter") || {
        error "list: failed to read storage"
        exit $EXIT_STORAGE_ERROR
    }

    # Apply limit
    if [[ -n "$limit" ]]; then
        result=$(echo "$result" | head -n "$limit")
    fi

    # Output as pretty-printed JSON array
    if [[ -z "$result" ]]; then
        echo "[]"
    else
        echo "$result" | jq -s '.'
    fi

    exit $EXIT_SUCCESS
}

