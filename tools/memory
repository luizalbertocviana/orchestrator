# =============================================================================
# Command: stats
# =============================================================================

cmd_stats() {
    local type=""
    local json_output=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)
                type="$2"
                shift 2
                ;;
            --json)
                json_output=true
                shift
                ;;
            -*)
                error "stats: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                shift
                ;;
        esac
    done

    # Acquire shared lock
    acquire_shared_lock

    if [[ ! -f "$MEMORY_FILE" ]]; then
        if [[ "$json_output" == true ]]; then
            echo '{"total": 0}'
        else
            echo "No items in memory."
        fi
        exit $EXIT_SUCCESS
    fi

    check_storage_thresholds

    # Calculate statistics from JSON array
    local stats
    if [[ -n "$type" ]]; then
        stats=$(jq --arg t "$type" '
            [.[] | select(.type == $t)] |
            {
                total: length,
                by_type: (group_by(.type) | map({key: .[0].type, value: length}) | from_entries),
                by_status: (map(select(.metadata.status != null)) | group_by(.metadata.status) | map({key: .[0].metadata.status, value: length}) | from_entries),
                by_priority: (group_by(.metadata.priority) | map({key: (.[0].metadata.priority | tostring), value: length}) | from_entries)
            }
        ' "$MEMORY_FILE")
    else
        stats=$(jq '
            {
                total: length,
                by_type: (group_by(.type) | map({key: .[0].type, value: length}) | from_entries),
                by_status: (map(select(.metadata.status != null)) | group_by(.metadata.status) | map({key: .[0].metadata.status, value: length}) | from_entries),
                by_priority: (group_by(.metadata.priority) | map({key: (.[0].metadata.priority | tostring), value: length}) | from_entries)
            }
        ' "$MEMORY_FILE")
    fi

    if [[ "$json_output" == true ]]; then
        echo "$stats" | jq .
    else
        echo "$stats" | jq -r '
            "Memory Statistics",
            "=================",
            "",
            "Total items: \(.total)",
            "",
            "By type:",
            (.by_type | to_entries | map("  \(.key): \(.value)") | .[]),
            "",
            "By status:",
            (.by_status | to_entries | map("  \(.key): \(.value)") | .[]),
            "",
            "By priority:",
            (.by_priority | to_entries | sort_by(.key | tonumber) | map("  \(.key): \(.value)") | .[])
        '
    fi

    exit $EXIT_SUCCESS
}

# =============================================================================
# Command: export
# =============================================================================

cmd_export() {
    local format="json"
    local output=""
    local type=""
    local since=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --format)
                format="$2"
                shift 2
                ;;
            --output)
                output="$2"
                shift 2
                ;;
            --type)
                type="$2"
                shift 2
                ;;
            --since)
                since="$2"
                shift 2
                ;;
            -*)
                error "export: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                shift
                ;;
        esac
    done

    # Validate format
    if ! validate_in "$format" "jsonl json markdown"; then
        error "export: invalid format '$format'. Valid: jsonl, json, markdown"
        exit $EXIT_INVALID_ARGS
    fi

    # Acquire shared lock
    acquire_shared_lock

    if [[ ! -f "$MEMORY_FILE" ]]; then
        exit $EXIT_SUCCESS
    fi

    # Build filter - chain select filters with |
    local filter='.'
    local conditions=()

    if [[ -n "$type" ]]; then
        conditions+=("select(.type == \"$type\")")
    fi

    if [[ -n "$since" ]]; then
        conditions+=("select(.metadata.created_iteration >= $since)")
    fi

    if [[ ${#conditions[@]} -gt 0 ]]; then
        for cond in "${conditions[@]}"; do
            filter="$filter | $cond"
        done
    fi

    # Export based on format
    local result
    case "$format" in
        jsonl)
            # Output as compact JSONL from array
            result=$(jq -c '.[]' "$MEMORY_FILE" 2>/dev/null | jq -c "$filter")
            ;;
        json)
            # For JSON array output, filter then output as pretty array
            result=$(jq -c '.[]' "$MEMORY_FILE" 2>/dev/null | jq -c "$filter" | jq -s '.')
            ;;
        markdown)
            # For markdown, iterate over array, filter, then format
            result=$(jq -r ".[] | $filter |
                \"## \\(.title)\\n\\n**Type:** \\(.type)\\n\\n\\(.content)\\n\"
            " "$MEMORY_FILE" 2>/dev/null)
            ;;
    esac

    # Output
    if [[ -n "$output" ]]; then
        echo "$result" > "$output" || {
            error "export: failed to write to output file"
            exit $EXIT_STORAGE_ERROR
        }
        echo "Exported to: $output"
    else
        echo "$result"
    fi

    exit $EXIT_SUCCESS
}

# =============================================================================
# Command: import
# =============================================================================

cmd_import() {
    local file=""
    local merge=false
    local replace=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --file)
                file="$2"
                shift 2
                ;;
            --merge)
                merge=true
                shift
                ;;
            --replace)
                replace=true
                shift
                ;;
            -*)
                error "import: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ -z "$file" ]]; then
        error "import: --file is required"
        exit $EXIT_INVALID_ARGS
    fi

    if [[ ! -f "$file" ]]; then
        error "import: file not found: $file"
        exit $EXIT_IMPORT_ERROR
    fi

    # Validate JSON
    if ! jq empty "$file" 2>/dev/null; then
        error "import: invalid JSON in file: $file"
        exit $EXIT_IMPORT_ERROR
    fi

    # Acquire exclusive lock
    acquire_exclusive_lock
    ensure_storage
    check_storage_thresholds

    local imported=0
    local skipped=0
    local updated=0

    # Check if file is JSONL (multiple objects) or JSON array
    local is_array
    is_array=$(jq -r 'if type == "array" then "yes" else "no" end' "$file" 2>/dev/null | head -1)

    if [[ "$is_array" == "yes" ]]; then
        # JSON array - iterate
        local count
        count=$(jq 'length' "$file")

        for ((i=0; i<count; i++)); do
            local item
            item=$(jq ".[$i]" "$file")
            local item_id
            item_id=$(echo "$item" | jq -r '.id')

            if item_exists "$item_id"; then
                if [[ "$replace" == true ]]; then
                    # Replace existing - update in array
                    local temp_file
                    temp_file=$(mktemp)
                    jq --arg id "$item_id" --argjson updated "$item" '
                        [.[] | if .id == $id then $updated else . end]
                    ' "$MEMORY_FILE" > "$temp_file"
                    mv "$temp_file" "$MEMORY_FILE"
                    updated=$((updated + 1))
                else
                    skipped=$((skipped + 1))
                fi
            else
                append_item "$item"
                imported=$((imported + 1))
            fi
        done
    else
        # JSONL - read line by line
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue

            local item_id
            item_id=$(echo "$line" | jq -r '.id' 2>/dev/null)

            if [[ -z "$item_id" || "$item_id" == "null" ]]; then
                error "import: invalid item format (missing id)"
                exit $EXIT_IMPORT_ERROR
            fi

            if item_exists "$item_id"; then
                if [[ "$replace" == true ]]; then
                    local temp_file
                    temp_file=$(mktemp)
                    jq --arg id "$item_id" --argjson updated "$line" '
                        [.[] | if .id == $id then $updated else . end]
                    ' "$MEMORY_FILE" > "$temp_file"
                    mv "$temp_file" "$MEMORY_FILE"
                    updated=$((updated + 1))
                else
                    skipped=$((skipped + 1))
                fi
            else
                append_item "$line"
                imported=$((imported + 1))
            fi
        done < "$file"
    fi

    echo "Import complete: $imported imported, $skipped skipped, $updated updated"
    exit $EXIT_SUCCESS
}

# =============================================================================
# Main Entry Point
# =============================================================================

main() {
    if [[ $# -lt 1 ]]; then
        usage
        exit $EXIT_INVALID_COMMAND
    fi

    local command="$1"
    shift

    case "$command" in
        onboard)
            cmd_onboard "$@"
            ;;
        create)
            cmd_create "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        show)
            cmd_show "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        delete)
            cmd_delete "$@"
            ;;
        search)
            cmd_search "$@"
            ;;
        link)
            cmd_link "$@"
            ;;
        unlink)
            cmd_unlink "$@"
            ;;
        stats)
            cmd_stats "$@"
            ;;
        export)
            cmd_export "$@"
            ;;
        import)
            cmd_import "$@"
            ;;
        version|--version|-v)
            cmd_version "$@"
            ;;
        *)
            error "unknown command: $command"
            usage
            exit $EXIT_INVALID_COMMAND
            ;;
    esac
}

main "$@"
