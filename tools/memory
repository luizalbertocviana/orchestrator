cmd_search() {
    local query=""
    local type=""
    local limit=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)
                type="$2"
                shift 2
                ;;
            --limit)
                limit="$2"
                shift 2
                ;;
            -*)
                error "search: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                if [[ -z "$query" ]]; then
                    query="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$query" ]]; then
        error "search: query is required"
        exit $EXIT_INVALID_ARGS
    fi

    # Acquire shared lock
    acquire_shared_lock

    if [[ ! -f "$MEMORY_FILE" ]]; then
        exit $EXIT_SUCCESS
    fi

    check_storage_thresholds

    # Read and filter - search in title, content, and tags
    local result
    result=$(jq -c '.[]' "$MEMORY_FILE" 2>/dev/null | jq -c --arg q "$query" '
        select(
            ((.title // "") | ascii_downcase | contains($q | ascii_downcase)) or
            ((.content // "") | ascii_downcase | contains($q | ascii_downcase)) or
            ((.metadata.tags // []) | map(ascii_downcase) | any(. | contains($q | ascii_downcase)))
        )
    ') || {
        error "search: failed to read storage"
        exit $EXIT_STORAGE_ERROR
    }

    # Apply type filter if specified
    if [[ -n "$type" ]]; then
        result=$(echo "$result" | jq -c --arg t "$type" 'select(.type == $t)')
    fi

    # Apply limit
    if [[ -n "$limit" ]]; then
        result=$(echo "$result" | head -n "$limit")
    fi

    # Output as pretty-printed JSON array
    if [[ -z "$result" ]]; then
        echo "[]"
    else
        echo "$result" | jq -s '.'
    fi

    exit $EXIT_SUCCESS
}

