                shift
                ;;
        esac
    done

    if [[ -z "$related_to" ]]; then
        error "link: --related-to is required"
        exit $EXIT_INVALID_ARGS
    fi

    if [[ -z "$relation" ]]; then
        error "link: --relation is required"
        exit $EXIT_INVALID_ARGS
    fi

    if ! validate_in "$relation" "$VALID_RELATIONS"; then
        error "link: invalid relation '$relation'. Valid: $VALID_RELATIONS"
        exit $EXIT_INVALID_ARGS
    fi

    # Acquire exclusive lock
    acquire_exclusive_lock

    if [[ ! -f "$MEMORY_FILE" ]]; then
        error "link: item '$id' not found"
        exit $EXIT_NOT_FOUND
    fi

    # Check if source item exists
    if ! item_exists "$id"; then
        error "link: item '$id' not found"
        exit $EXIT_NOT_FOUND
    fi

    # Check if target item exists
    if ! item_exists "$related_to"; then
        error "link: item '$related_to' not found"
        exit $EXIT_NOT_FOUND
    fi

    # Get source item from array and add relation
    local item updated_item
    item=$(jq -c '.[]' "$MEMORY_FILE" | jq --arg id "$id" 'select(.id == $id)')

    updated_item=$(echo "$item" | jq --arg to "$related_to" --arg rel "$relation" '
        .relations += [{to: $to, relation: $rel}]
    ')

    # Write updated item back
    local temp_file
    temp_file=$(mktemp) || {
        error "link: failed to create temp file"
        exit $EXIT_STORAGE_ERROR
    }

    jq --arg id "$id" --argjson updated "$updated_item" '
        [.[] | if .id == $id then $updated else . end]
    ' "$MEMORY_FILE" > "$temp_file" || {
        rm -f "$temp_file"
        error "link: failed to update item"
        exit $EXIT_STORAGE_ERROR
    }

    mv "$temp_file" "$MEMORY_FILE" || {
        error "link: failed to replace storage file"
        exit $EXIT_STORAGE_ERROR
    }

    # Output updated item
    echo "$updated_item" | jq .
    exit $EXIT_SUCCESS
}

