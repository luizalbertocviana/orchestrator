# =============================================================================
# Command: update
# =============================================================================

cmd_update() {
    if [[ $# -lt 1 ]]; then
        error "update: item ID is required"
        exit $EXIT_INVALID_ARGS
    fi

    local id="$1"
    shift

    local title=""
    local content=""
    local status=""
    local priority=""
    local assignee=""
    local tags=""
    local add_tags=""
    local remove_tags=""
    local value=""
    local path=""
    local affects=""

    # Type-specific fields for gap fixes
    local due_iteration=""
    local category=""
    local trend=""
    local alternatives=""
    local decision_status=""
    local checksum=""
    local artifact_type=""
    local resolution=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title)
                title="$2"
                shift 2
                ;;
            --content)
                content="$2"
                shift 2
                ;;
            --status)
                status="$2"
                shift 2
                ;;
            --priority)
                priority="$2"
                shift 2
                ;;
            --assignee)
                assignee="$2"
                shift 2
                ;;
            --tags)
                tags="$2"
                shift 2
                ;;
            --add-tags)
                add_tags="$2"
                shift 2
                ;;
            --remove-tags)
                remove_tags="$2"
                shift 2
                ;;
            --value)
                value="$2"
                shift 2
                ;;
            --path)
                path="$2"
                shift 2
                ;;
            --affects)
                affects="$2"
                shift 2
                ;;
            --due-iteration)
                due_iteration="$2"
                shift 2
                ;;
            --category)
                category="$2"
                shift 2
                ;;
            --trend)
                trend="$2"
                shift 2
                ;;
            --alternatives)
                alternatives="$2"
                shift 2
                ;;
            --decision-status)
                decision_status="$2"
                shift 2
                ;;
            --checksum)
                checksum="$2"
                shift 2
                ;;
            --artifact-type)
                artifact_type="$2"
                shift 2
                ;;
            --resolution)
                resolution="$2"
                shift 2
                ;;
            -*)
                error "update: unknown option: $1"
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                shift
                ;;
        esac
    done

    # Validate inputs before acquiring lock
    if [[ -n "$status" ]] && ! validate_in "$status" "$VALID_STATUSES"; then
        error "update: invalid status '$status'. Valid: $VALID_STATUSES"
        exit $EXIT_INVALID_ARGS
    fi

    if [[ -n "$priority" ]] && ! validate_in "$priority" "$VALID_PRIORITIES"; then
        error "update: invalid priority '$priority'. Valid: 0-4"
        exit $EXIT_INVALID_ARGS
    fi

    if [[ -n "$decision_status" ]] && ! validate_in "$decision_status" "$VALID_DECISION_STATUS"; then
        error "update: invalid decision status '$decision_status'. Valid: $VALID_DECISION_STATUS"
        exit $EXIT_INVALID_ARGS
    fi

    if [[ -n "$artifact_type" ]] && ! validate_in "$artifact_type" "$VALID_ARTIFACT_TYPES"; then
        error "update: invalid artifact type '$artifact_type'. Valid: $VALID_ARTIFACT_TYPES"
        exit $EXIT_INVALID_ARGS
    fi

    if [[ -n "$title" ]] && ! validate_input "$title"; then
        error "update: warning: title contains special shell characters - will be escaped"
    fi
    if [[ -n "$content" ]] && ! validate_input "$content"; then
        error "update: warning: content contains special shell characters - will be escaped"
    fi

    # Acquire exclusive lock
    acquire_exclusive_lock

    if [[ ! -f "$MEMORY_FILE" ]]; then
        error "update: item '$id' not found"
        exit $EXIT_NOT_FOUND
    fi

    # Find item from array
    local item
    item=$(jq -c '.[]' "$MEMORY_FILE" 2>/dev/null | jq --arg id "$id" 'select(.id == $id)')

    if [[ -z "$item" ]]; then
        error "update: item '$id' not found"
        exit $EXIT_NOT_FOUND
    fi

    # Prepare JSON values for jq
    local tags_json="null" add_tags_json="null" remove_tags_json="null"
    local affects_json="null" alternatives_json="null"
    
    [[ -n "$tags" ]] && tags_json=$(echo "$tags" | tr ',' '\n' | jq -R . | jq -s .)
    [[ -n "$add_tags" ]] && add_tags_json=$(echo "$add_tags" | tr ',' '\n' | jq -R . | jq -s .)
    [[ -n "$remove_tags" ]] && remove_tags_json=$(echo "$remove_tags" | tr ',' '\n' | jq -R . | jq -s .)
    [[ -n "$affects" ]] && affects_json=$(echo "$affects" | tr ',' '\n' | jq -R . | jq -s .)
    [[ -n "$alternatives" ]] && alternatives_json=$(echo "$alternatives" | tr ',' '\n' | jq -R . | jq -s .)

    local timestamp_updated
    timestamp_updated=$(get_timestamp)

    # Single jq transformation for all updates - eliminates 20+ separate jq calls
    local updated_item
    updated_item=$(jq -c \
        --arg title "$title" \
        --arg content "$content" \
        --arg status "$status" \
        --arg priority "$priority" \
        --arg assignee "$assignee" \
        --argjson tags "$tags_json" \
        --argjson add_tags "$add_tags_json" \
        --argjson remove_tags "$remove_tags_json" \
        --arg value "$value" \
        --arg path "$path" \
        --argjson affects "$affects_json" \
        --arg due_iteration "$due_iteration" \
        --arg category "$category" \
        --arg trend "$trend" \
        --argjson alternatives "$alternatives_json" \
        --arg decision_status "$decision_status" \
        --arg checksum "$checksum" \
        --arg artifact_type "$artifact_type" \
        --arg resolution "$resolution" \
        --arg timestamp_updated "$timestamp_updated" \
        '
        . as $orig |
        # Title
        (if $title != "" then .title = $title else . end) |
        # Content
        (if $content != "" then .content = $content else . end) |
        # Status
        (if $status != "" then .metadata.status = $status else . end) |
        # Priority
        (if $priority != "" then .metadata.priority = ($priority | tonumber) else . end) |
        # Assignee
        (if $assignee != "" then .metadata.assignee = $assignee else . end) |
        # Tags (replace)
        (if $tags != null then .metadata.tags = $tags else . end) |
        # Add tags
        (if $add_tags != null then .metadata.tags = ((.metadata.tags // []) + $add_tags | unique) else . end) |
        # Remove tags
        (if $remove_tags != null then .metadata.tags = ((.metadata.tags // []) - $remove_tags) else . end) |
        # Value (metric)
        (if $value != "" then .metadata.type_specific.value = ($value | tonumber) else . end) |
        # Path (artifact)
        (if $path != "" then .metadata.type_specific.path = $path else . end) |
        # Affects (blocker)
        (if $affects != null then .metadata.type_specific.affects = $affects else . end) |
        # Due iteration (task)
        (if $due_iteration != "" then .metadata.type_specific.due_iteration = ($due_iteration | tonumber) else . end) |
        # Category (note)
        (if $category != "" then .metadata.type_specific.category = $category else . end) |
        # Trend (metric)
        (if $trend != "" then .metadata.type_specific.trend = $trend else . end) |
        # Alternatives (decision)
        (if $alternatives != null then .metadata.type_specific.alternatives = $alternatives else . end) |
        # Decision status
        (if $decision_status != "" then .metadata.type_specific.status = $decision_status else . end) |
        # Checksum (artifact)
        (if $checksum != "" then .metadata.type_specific.checksum = $checksum else . end) |
        # Artifact type
        (if $artifact_type != "" then .metadata.type_specific.artifact_type = $artifact_type else . end) |
        # Resolution (blocker)
        (if $resolution != "" then .metadata.type_specific.resolution = $resolution else . end) |
        # Update timestamp
        .timestamp_updated = $timestamp_updated
        ' <<< "$item") || {
        error "update: failed to process item"
        exit $EXIT_STORAGE_ERROR
    }

    # Write updated item back using single jq pass
    local temp_file
    temp_file=$(mktemp) || {
        error "update: failed to create temp file"
        exit $EXIT_STORAGE_ERROR
    }

    jq --arg id "$id" --argjson updated "$updated_item" '
        [.[] | if .id == $id then $updated else . end]
    ' "$MEMORY_FILE" > "$temp_file" || {
        rm -f "$temp_file"
        error "update: failed to update item"
        exit $EXIT_STORAGE_ERROR
    }

    mv "$temp_file" "$MEMORY_FILE" || {
        error "update: failed to replace storage file"
        exit $EXIT_STORAGE_ERROR
    }

    # Output updated item
    echo "$updated_item" | jq .
    exit $EXIT_SUCCESS
}

